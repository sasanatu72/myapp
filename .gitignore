# =========================
# Project root ignore rules
# =========================

# ----- Python / FastAPI (backend) -----
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.env
backend/.venv/
backend/venv/

# SQLite
backend/*.db
backend/*.sqlite3

# ----- Flutter / Dart (frontend) -----
frontend/.dart_tool/
frontend/build/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.packages

# Android build/cache
frontend/android/.gradle/
frontend/android/app/build/

# iOS build/cache
frontend/ios/Pods/
frontend/ios/.symlinks/
frontend/ios/Flutter/ephemeral/

# ----- Editor / OS -----
.vscode/
.idea/
.DS_Store
Thumbs.db

# ----- Personal memo files -----
memo.md
memo.txt